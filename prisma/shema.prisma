generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
url      = env("DATABASE_URL")
}

// comando: npx prisma db push - para criar a tabela no banco de dados
// comando: npx prisma db pull - para atualizar o schema.prisma com as tabelas do banco de dados
model User {
  id        Int      @id @default(autoincrement())
  name String
  email String @unique

}